{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Work Pulse Checker",
  "version": "0.1.0",
  "identifier": "com.perorin0418.work-pulse-checker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Work Pulse Checker",
        "label": "main",
        "width": 1300,
        "height": 1000,
        "visible": false,
        "skipTaskbar": false,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "ja-JP"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
